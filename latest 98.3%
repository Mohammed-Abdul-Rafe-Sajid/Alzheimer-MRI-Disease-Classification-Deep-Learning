sform = transform\n\n    def __len__(self):\n        return len(self.df)\n\n    def __getitem__(self, idx):\n        image_bytes = self.df.iloc[idx]['image']['bytes']\n        label = self.df.iloc[idx]['label']\n        # Convert bytes to grayscale image (1 channel)\n        image = Image.open(io.BytesIO(image_bytes)).convert(\"L\")\n\n        if self.transform:\n            image = self.transform(image)\n\n        return image, label","metadata":{"id":"p-wlnFXNL7I7","trusted":true,"execution":{"iopub.status.busy":"2026-01-25T11:36:36.388750Z","iopub.execute_input":"2026-01-25T11:36:36.389048Z","iopub.status.idle":"2026-01-25T11:36:36.400101Z","shell.execute_reply.started":"2026-01-25T11:36:36.389027Z","shell.execute_reply":"2026-01-25T11:36:36.395241Z"}},"outputs":[],"execution_count":42},{"cell_type":"markdown","source":"## Defining the CNN Model","metadata":{"id":"g2AMf-UHwHQn"}},{"cell_type":"markdown","source":"- Notice input channel , kept =`1","metadata":{"id":"a2CFGXVBwN2q"}},{"cell_type":"code","source":"import torch\nimport torch.nn as nn\nimport torch.nn.functional as F\n\nclass SimpleCC1(nn.Module):\n    def __init__(self):\n        super(SimpleCC1, self).__init__()\n\n        self.conv1 = nn.Conv2d(1, 16, kernel_size=3, padding=1)   # Input: 1 channel (Grayscale), Output: 16 feature maps\n        self.pool = nn.MaxPool2d(2, 2)                            # Downsample by 2x\n        self.conv2 = nn.Conv2d(16, 32, kernel_size=3, padding=1)\n        self.conv3 = nn.Conv2d(32, 64, kernel_size=3, padding=1)\n\n        # Manually set the flattened size based on observed tensor shape [64, 64, 16, 16]\n        self._to_linear = 64 * 16 * 16 # <- Manually calculated flattened size\n\n        self.fc1 = nn.Linear(self._to_linear, 128)\n        self.fc2 = nn.Linear(128, 4)  # 4 classes for Alzheimer\n\n    def forward(self, x):\n        x = self.pool(F.relu(self.conv1(x)))  # Conv1 + ReLU + Pool\n        x = self.pool(F.relu(self.conv2(x)))  # Conv2 + ReLU + Pool\n        x = self.pool(F.relu(self.conv3(x)))  # Conv3 + ReLU + Pool\n\n\n        x = x.view(-1, self._to_linear)          # Flatten before FC\n        x = F.relu(self.fc1(x))               # FC1 + ReLU\n        x = self.fc2(x)                       # Output layer (logits)\n        return x","metadata":{"id":"z8PjSp7f3VUS","trusted":true,"execution":{"iopub.status.busy":"2026-01-25T11:36:44.324967Z","iopub.execute_input":"2026-01-25T11:36:44.325246Z","iopub.status.idle":"2026-01-25T11:36:44.337225Z","shell.execute_reply.started":"2026-01-25T11:36:44.325228Z","shell.execute_reply":"2026-01-25T11:36:44.333159Z"}},"outputs":[],"execution_count":43},{"cell_type":"markdown","source":"This below step is done to get the best mean and std for normalizing","metadata":{"id":"ltaTHstZwYkL"}},{"cell_type":"code","source":"from torch.utils.data import DataLoader\nimport torch\n\n# Temporary loader without normalization\ntemp_transform = transforms.Compose([\n    transforms.ToTensor()\n])\ntemp_dataset = AlzheimerMRIDataset(train_df, transform=temp_transform)\ntemp_loader = DataLoader(temp_dataset, batch_size=64, shuffle=False)\n\ndef compute_mean_std(loader):\n    mean = 0.0\n    std = 0.0\n    total_images = 0\n\n    for images, _ in loader:\n        images = images.view(images.size(0), -1)  # Flatten each image\n        mean += images.mean(1).sum()\n        std += images.std(1).sum()\n        total_images += images.size(0)\n\n    mean /= total_images\n    std /= total_images\n    return mean.item(), std.item()\n\nmean, std = compute_mean_std(temp_loader)\nprint(f\"Mean: {mean:.4f}, Std: {std:.4f}\")\n","metadata":{"id":"TOJ2WiguFDB1","outputId":"5c6d5b62-9b91-4e2c-d66b-0ab61a6f707d","trusted":true,"execution":{"iopub.status.busy":"2026-01-25T11:36:49.326672Z","iopub.execute_input":"2026-01-25T11:36:49.326919Z","iopub.status.idle":"2026-01-25T11:36:51.230456Z","shell.execute_reply.started":"2026-01-25T11:36:49.326901Z","shell.execute_reply":"2026-01-25T11:36:51.225638Z"}},"outputs":[{"name":"stdout","text":"Mean: 0.2786, Std: 0.3245\n","output_type":"stream"}],"execution_count":44},{"cell_type":"markdown","source":"## Transformations","metadata":{"id":"PCfvq23dwgPR"}},{"cell_type":"code","source":"from torchvision import transforms\n\n# Augmented training transform with correct normalization\ntrain_transform_augmented = transforms.Compose([\n    transforms.RandomRotation(10),\n    transforms.RandomHorizontalFlip(),\n    transforms.ToTensor(),\n    transforms.Normalize((0.2786,), (0.3245,))\n])\n\n# Test transform with correct normalization\ntest_transform = transforms.Compose([\n    transforms.ToTensor(),\n    transforms.Normalize((0.2786,), (0.3245,))\n])","metadata":{"id":"ApKVt462jvWm","trusted":true,"execution":{"iopub.status.busy":"2026-01-25T11:36:58.226463Z","iopub.execute_input":"2026-01-25T11:36:58.226766Z","iopub.status.idle":"2026-01-25T11:36:58.236884Z","shell.execute_reply.started":"2026-01-25T11:36:58.226745Z","shell.execute_reply":"2026-01-25T11:36:58.232487Z"}},"outputs":[],"execution_count":45},{"cell_type":"markdown","source":"## Defining the augmented dataset and loader\n- no need to augment testing dataset","metadata":{"id":"8CBKUyz6wkHF"}},{"cell_type":"code","source":"from torch.utils.data import DataLoader\n\n# Datasets with new transform using the AlzheimerMRIDataset\ntrain_dataset_augmented = AlzheimerMRIDataset(train_df, transform=train_transform_augmented)\ntest_dataset = AlzheimerMRIDataset(test_df, transform=test_transform)\n\n# DataLoaders\ntrain_loader_augmented = DataLoader(train_dataset_augmented, batch_size=64, shuffle=True)\ntest_loader = DataLoader(test_dataset, batch_size=64, shuffle=False)","metadata":{"id":"r7bx-gXYyNXy","trusted":true,"execution":{"iopub.status.busy":"2026-01-25T11:37:03.345573Z","iopub.execute_input":"2026-01-25T11:37:03.345867Z","iopub.status.idle":"2026-01-25T11:37:03.354557Z","shell.execute_reply.started":"2026-01-25T11:37:03.345847Z","shell.execute_reply":"2026-01-25T11:37:03.351328Z"}},"outputs":[],"execution_count":46},{"cell_type":"markdown","source":"## Initializing the model, and defining the optimizer and loss","metadata":{"id":"yycoMXu_w1ft"}},{"cell_type":"code","source":"import torch.nn as nn\nimport torch.optim as optim\n\n# initialize model\naug_model = SimpleCC1().to(device)\n\n# Loss and optimizer\ncriterion = nn.CrossEntropyLoss()\noptimizer = optim.Adam(aug_model.parameters(), lr=0.001)","metadata":{"id":"qM9tAZZhyPd6","trusted":true,"execution":{"iopub.status.busy":"2026-01-25T11:37:06.534982Z","iopub.execute_input":"2026-01-25T11:37:06.535223Z","iopub.status.idle":"2026-01-25T11:37:06.557427Z","shell.execute_reply.started":"2026-01-25T11:37:06.535204Z","shell.execute_reply":"2026-01-25T11:37:06.552947Z"}},"outputs":[],"execution_count":47},{"cell_type":"markdown","source":"## Training the model","metadata":{"id":"zrLGup3jw8Oe"}},{"cell_type":"code","source":"# Training loop\nnum_epochs = 5\ntrain_accuracy = []\ntrain_loss = []\n\nfor epoch in range(num_epochs):\n    aug_model.train()\n    running_loss = 0.0\n    correct = 0\n    total = 0\n\n    for images, labels in train_loader_augmented:\n        images, labels = images.to(device), labels.to(device)\n\n        optimizer.zero_grad()\n        outputs = aug_model(images)\n        loss = criterion(outputs, labels)\n        loss.backward()\n        optimizer.step()\n\n        running_loss += loss.item()\n        _, predicted = torch.max(outputs.data, 1)\n        total += labels.size(0)\n        correct += (predicted == labels).sum().item()\n\n    epoch_loss = running_loss / len(train_loader_augmented)\n    epoch_acc = 100 * correct / total\n    train_loss.append(epoch_loss)\n    train_accuracy.append(epoch_acc)\n\n    print(f\"Epoch [{epoch+1}/{num_epochs}], Loss: {epoch_loss:.4f}, Accuracy: {epoch_acc:.2f}%\")","metadata":{"id":"oIcc0XHXzjxZ","outputId":"168a0ff2-2922-4017-8d11-947a70c047a7","trusted":true,"execution":{"iopub.status.busy":"2026-01-25T11:37:09.610077Z","iopub.execute_input":"2026-01-25T11:37:09.610385Z","iopub.status.idle":"2026-01-25T11:37:44.030470Z","shell.execute_reply.started":"2026-01-25T11:37:09.610365Z","shell.execute_reply":"2026-01-25T11:37:44.025632Z"}},"outputs":[{"name":"stdout","text":"Epoch [1/5], Loss: 1.0230, Accuracy: 51.64%\nEpoch [2/5], Loss: 0.9418, Accuracy: 54.30%\nEpoch [3/5], Loss: 0.9131, Accuracy: 55.53%\nEpoch [4/5], Loss: 0.8717, Accuracy: 57.83%\nEpoch [5/5], Loss: 0.8426, Accuracy: 60.51%\n","output_type":"stream"}],"execution_count":48},{"cell_type":"markdown","source":"## Testing the model","metadata":{"id":"8HupM0KSxA-c"}},{"cell_type":"code","source":"def test_model(model, test_loader):\n    model.eval()  # Evaluation mode\n    correct = 0\n    total = 0\n    with torch.no_grad():  # No gradient calculation for testing\n        for images, labels in test_loader:\n            images, labels = images.to(device), labels.to(device)\n            outputs = model(images)\n            _, predicted = torch.max(outputs.data, 1)\n            total += labels.size(0)\n            correct += (predicted == labels).sum().item()\n    print(f\"Test Accuracy: {100 * correct / total:.2f}%\")\n\n# Run the test\ntest_model(aug_model, test_loader)\n","metadata":{"id":"HJY5ZBTcHj_C","outputId":"58af3191-378c-495c-9930-270534548800","trusted":true,"execution":{"iopub.status.busy":"2026-01-25T11:37:48.101795Z","iopub.execute_input":"2026-01-25T11:37:48.102066Z","iopub.status.idle":"2026-01-25T11:37:51.490215Z","shell.execute_reply.started":"2026-01-25T11:37:48.102046Z","shell.execute_reply":"2026-01-25T11:37:51.485435Z"}},"outputs":[{"name":"stdout","text":"Test Accuracy: 61.19%\n","output_type":"stream"}],"execution_count":49},{"cell_type":"markdown","source":"So, after applying data augmentation, we can see that the accuracy has fallen down to 64.22%, we already had a very good accuracy of 96.95% without any data Augmentation, this may be due to the fact that medical iomages ae already well processed and further augmenting the image wont help any further, instead is makin it distorted","metadata":{"id":"xLEpgiXjJ5cV"}},{"cell_type":"markdown","source":"\"Adding random rotations, flips, affine transforms, or brightness shifts can harm the signal in medical datasets like this one. These images aren’t meant to vary like natural scenes or digits (like MNIST).\"","metadata":{"id":"QurRlEALK00K"}},{"cell_type":"markdown","source":"## Saving the model","metadata":{"id":"rW_OTa-t1hVy"}},{"cell_type":"code","source":"torch.save(aug_model.state_dict(), 'alzheimer-augmented-model.pth')","metadata":{"id":"t64bGfgu1WDx"},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"##--------------------------------------\n## ResNet\n##-----------------------------------------","metadata":{"id":"AZWrzK5pTxmw","jp-MarkdownHeadingCollapsed":true}},{"cell_type":"markdown","source":"##  What is ResNet?\nResNet stands for Residual Network.\nIt is a deep convolutional neural network (CNN) architecture that solves the problem of vanishing gradients and allows training of very deep models (like 50 or even 152 layers).","metadata":{"id":"pIhU2nkcyNTu","jp-MarkdownHeadingCollapsed":true}},{"cell_type":"markdown","source":"## ResNet pros\n- Powerful general feature extractor (especially if pretrained)\n\n- Learns both low-level (edges) and high-level (shapes, patterns)\n\n- Less prone to overfitting if you freeze most layers","metadata":{"id":"VGtPoAlgyXVc","jp-MarkdownHeadingCollapsed":true}},{"cell_type":"markdown","source":"## ResNet cons\n- Computationally Heavy\n\n- fixed Architecture: You can't easily modify it like you can with your own CNN. It’s a little rigid, especially with pretrained weights.\n\n- After a certain depth (like ResNet-152), adding more layers doesn't give significant improvements.","metadata":{"id":"_15WlrdEzb7i"}},{"cell_type":"markdown","source":"### Though there isn't much chance for it to perform better on our dataset, we will carry out for observations, both from scratch and pretrained (transfer learning)","metadata":{"id":"1obhyBWTz2w2","jp-MarkdownHeadingCollapsed":true}},{"cell_type":"markdown","source":"# 1 . From Scratch","metadata":{"id":"cEJbS9PE0PX7"}},{"cell_type":"markdown","source":"## Creating the Model","metadata":{"id":"3WFn-6SIzOjb"}},{"cell_type":"code","source":"import torchvision.models as models\nimport torch.nn as nn\n\nclass ResNet18Grayscale(nn.Module):\n    def __init__(self, num_classes=4):\n        super(ResNet18Grayscale, self).__init__()\n        # Load standard ResNet18 model without pretraining\n        self.model = models.resnet18(pretrained=False)\n\n        # Modify the first conv layer to accept 1 input channel (instead of 3 for RGB)\n        self.model.conv1 = nn.Conv2d(1, 64, kernel_size=7, stride=2, padding=3, bias=False)\n\n        # Modify the final fully connected layer to output 4 classes\n        self.model.fc = nn.Linear(self.model.fc.in_features, num_classes)\n\n    def forward(self, x):\n        return self.model(x)\n","metadata":{"id":"Mal-Q4fSVFGG","trusted":true,"execution":{"iopub.status.busy":"2026-01-25T11:42:11.797469Z","iopub.execute_input":"2026-01-25T11:42:11.797747Z","iopub.status.idle":"2026-01-25T11:42:11.808030Z","shell.execute_reply.started":"2026-01-25T11:42:11.797728Z","shell.execute_reply":"2026-01-25T11:42:11.803604Z"}},"outputs":[],"execution_count":51},{"cell_type":"markdown","source":"## Defining the model, optimizer and loss","metadata":{"id":"e1mraITX0afI"}},{"cell_type":"code","source":"import torch.optim as optim\nimport torch.nn as nn\n\n# Set device\ndevice = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n\n# Model\nmodel = ResNet18Grayscale(num_classes=4).to(device)\n\n# Loss and optimizer\ncriterion = nn.CrossEntropyLoss()\noptimizer = optim.Adam(model.parameters(), lr=0.001)\n","metadata":{"id":"e0Pni5UMUP-V","outputId":"d78edade-9287-4fb5-ee3b-d3ae8baa1a60","trusted":true,"execution":{"iopub.status.busy":"2026-01-25T11:4