tadata":{"id":"NVmyq5SEK5Cb"}},{"cell_type":"code","source":"import torchvision.models as models\nimport torch.nn as nn\n\n# Load pretrained ResNet18\n# model = models.resnet18(pretrained=True)\nmodel = models.resnet18(weights=None)\n\n# Freeze all layers (so only the final layer is trained)-> this is done to reduce execution time,\n# if you are working on a gpu it is recomended to remove this, so that it gets trained well\nfor param in model.parameters():\n    param.requires_grad = False\n\n# Replace the final fully connected layer to match 4 output classes\nnum_ftrs = model.fc.in_features\nmodel.fc = nn.Linear(num_ftrs, 4)  # 4 classes\n\n# Move model to GPU (if available)\ndevice = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\nmodel = model.to(device)\n","metadata":{"id":"IS2VP9_q586W","trusted":true,"execution":{"iopub.status.busy":"2026-01-25T12:06:26.701048Z","iopub.execute_input":"2026-01-25T12:06:26.701367Z","iopub.status.idle":"2026-01-25T12:06:26.812498Z","shell.execute_reply.started":"2026-01-25T12:06:26.701347Z","shell.execute_reply":"2026-01-25T12:06:26.808649Z"}},"outputs":[],"execution_count":64},{"cell_type":"markdown","source":"## Defining Loss and optimizer","metadata":{"id":"Q-mh7sl2LUEz"}},{"cell_type":"code","source":"import torch.optim as optim\nimport torch.nn as nn\n\n# Loss function\ncriterion = nn.CrossEntropyLoss()\n\n# Optimizer (only parameters of the final layer are being updated)\noptimizer = optim.Adam(model.fc.parameters(), lr=0.001)\n","metadata":{"id":"PG7c3hYi1-0a","trusted":true,"execution":{"iopub.status.busy":"2026-01-25T12:06:31.569628Z","iopub.execute_input":"2026-01-25T12:06:31.569933Z","iopub.status.idle":"2026-01-25T12:06:31.580011Z","shell.execute_reply.started":"2026-01-25T12:06:31.569913Z","shell.execute_reply":"2026-01-25T12:06:31.576084Z"}},"outputs":[],"execution_count":65},{"cell_type":"code","source":"from tqdm import tqdm\n","metadata":{"id":"B2hYg8GZ_gkN","trusted":true,"execution":{"iopub.sta